void __fastcall TForm3::Button4Click(TObject *Sender)
{

    // Buscar libro por ID
	int IDModificar = stoi(AnsiString(CasillaIdBuscarLibroModificar->Text).c_str());

	NodoLibros* actual = listaLibros.getPrimerNodo1();


	while (actual != nullptr)
	{
		if (actual->datos_libros.Id == IDModificar)
		{
			// Modificar campos
			actual->datos_libros.Id = stoi(AnsiString(CasillaIdModificarLibro->Text).c_str());
			actual->datos_libros.Nombre = AnsiString(CasillaNombreModificarLibro->Text).c_str();
			actual->datos_libros.Area = AnsiString(CasillaAreaModificarLibro->Text).c_str();
			actual->datos_libros.SubArea = AnsiString(CasillaSubAreaModificarLibro->Text).c_str();
			actual->datos_libros.Autores = AnsiString(CasillaAutoresModificarLibro->Text).c_str();
			actual->datos_libros.Editorial = AnsiString(CasillaEditorialModificarLibro->Text).c_str();
			actual->datos_libros.AnoPublicacion = AnsiString(CasillaAnoPublicacionModificarLibro->Text).c_str();
			actual->datos_libros.Estado = AnsiString(CasillaEstadoModificarLibro->Text).c_str();
			actual->datos_libros.CantidadDisponible = stoi(AnsiString(CasillaCantidadModificarLibro->Text).c_str());


			if (actual->datos.Id.IsEmpty() || actual->datos.Nombre.IsEmpty() || actual->datos.Area.IsEmpty() || actual->datos.SubArea.IsEmpty()
			actual->datos.Autores.IsEmpty() || actual->datos.Editorial.IsEmpty() || actual->datos.AnoPublicacion.IsEmpty()
			actual->datos.Estado.IsEmpty()|| actual->datos.CantidadDisponible.IsEmpty())
			{
			ShowMessage("Por favor, complete todos los campos.");
			return;
			}

			break;
		}
		actual = actual->siguiente;
	}

	// Guardar cambios en CSV
	listaLibros.GuardarListaLibrosEnCSV();

    PlanillaLibroModificado->ColCount = 2;
	PlanillaLibroModificado->RowCount = 9;


	PlanillaLibroModificado->Cells[0][0] = CasillaIdModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][1] = CasillaNombreModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][2] = CasillaAreaModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][3] = CasillaSubAreaModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][4] = CasillaAutoresModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][5] = CasillaEditorialModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][6] = CasillaAnoPublicacionModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][7] = CasillaEstadoModificarLibro->Text;
	PlanillaLibroModificado->Cells[0][8] = CasillaCantidadModificarLibro->Text;

	ShowMessage("Modificación realizada.");

}
