   void __fastcall TForm3::MostrarLibros() {
	NodoLibros* actual = listaLibros.PrimerNodo1;

	int cantidad = 0;
	NodoLibros * temp = actual;
	while (temp != nullptr) {
		cantidad++;
		temp = temp->siguiente;
	}

	PlanillaMostrarLibros->RowCount = cantidad + 1;

	// Opcional: agregar encabezados si es la primera vez
	PlanillaMostrarLibros->Cells[0][0] = "ID";
	PlanillaMostrarLibros->Cells[1][0] = "Nombre";
	PlanillaMostrarLibros->Cells[2][0] = "Area";
	PlanillaMostrarLibros->Cells[3][0] = "SubArea";
	PlanillaMostrarLibros->Cells[4][0] = "Autores";
	PlanillaMostrarLibros->Cells[5][0] = "Editorial";
	PlanillaMostrarLibros->Cells[6][0] = "Ańo";
	PlanillaMostrarLibros->Cells[7][0] = "Estado";
	PlanillaMostrarLibros->Cells[8][0] = "Cant.";
	PlanillaMostrarLibros->Cells[9][0] = "Ubicacion";

	int fila = 1;
	while (actual != nullptr) {
		PlanillaMostrarLibros->Cells[0][fila] = IntToStr(actual->datos_libros.Id);
		PlanillaMostrarLibros->Cells[1][fila] = actual->datos_libros.Nombre.c_str();
		PlanillaMostrarLibros->Cells[2][fila] = actual->datos_libros.Area.c_str();
		PlanillaMostrarLibros->Cells[3][fila] = actual->datos_libros.SubArea.c_str();
		PlanillaMostrarLibros->Cells[4][fila] = actual->datos_libros.Autores.c_str();
		PlanillaMostrarLibros->Cells[5][fila] = actual->datos_libros.Editorial.c_str();
		PlanillaMostrarLibros->Cells[6][fila] = actual->datos_libros.AnoPublicacion.c_str();
		PlanillaMostrarLibros->Cells[7][fila] = actual->datos_libros.Estado.c_str();
		PlanillaMostrarLibros->Cells[8][fila] = IntToStr(actual->datos_libros.CantidadDisponible);
		PlanillaMostrarLibros->Cells[9][fila] = actual->datos_libros.ubicacion.c_str();




		actual = actual->siguiente;
		fila++;
	}
}





void __fastcall TForm3::Button1Click(TObject *Sender)
{
       MostrarLibros();
}
