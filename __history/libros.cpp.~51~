int Libros::DarDeBajaLibro(int idaux) {


	int bandera = 0;



	NodoLibros* actual = PrimerNodo1;
	NodoLibros* anterior = nullptr;

	while (actual != nullptr) {
		if (idaux == actual->datos_libros.Id) {

			if (anterior == nullptr) {

				PrimerNodo1 = actual->siguiente;
			} else {

				anterior->siguiente = actual->siguiente;

			}

			delete actual;




			GuardarListaLibrosEnCSV();
			bandera = 1;
			ShowMessage("El libro se elimino correctamente");
			return 1;
		}

		anterior = actual;
		actual = actual->siguiente;


	}
	if (bandera == 0) {
		ShowMessage("El ID Libro Buscado no existe , Ingrese otro.");
	}

}
void Libros::GuardarListaLibrosEnCSV() {
	ofstream ArchivoLibros("ListaLibros.csv");
	if (!ArchivoLibros) {

		return;
	}

	NodoLibros* actual = PrimerNodo1;
	while (actual != nullptr) {
		ArchivoLibros << actual->datos_libros.Id << ","
		              << actual->datos_libros.Nombre << "," << actual->datos_libros.Area << ","<<actual->datos_libros.ubicacion<<"," << actual->datos_libros.SubArea << ","
		              << actual->datos_libros.Autores << ","
		              << actual->datos_libros.Editorial << ","
		              << actual->datos_libros.AnoPublicacion << "," << actual->datos_libros.Estado << "," << actual->datos_libros.CantidadDisponible << endl;
		actual = actual->siguiente;
	}

	ArchivoLibros.close();
}

int Libros::RealizarPrestamo(Socios &objSocios,string apellidoaux,string areaaux,string NombreLibroReservar,int ReservarDias,string fechadelprestamo) {   //FALTA TERMINAAAAAAR , ESTA INCOMPLETO



	NodoSocios *actualSocios = objSocios.primerNodo;


	int libroReservar = 1;
	int bandera = 0;
	int SocioEncontrado=0;




	while (actualSocios != nullptr) {

		if (apellidoaux == actualSocios->datos_socios.Apellido) {

			SocioEncontrado=1;

			NodoLibros *actual = PrimerNodo1;
			bandera = 0;
			//	cout << "Ingrese el Area del libro" << endl;
			//	getline(cin, areaaux);



			while (actual != nullptr) {


				if (areaaux == actual->datos_libros.Area && NombreLibroReservar == actual->datos_libros.Nombre) {

					bandera = 1;

					if (actual->datos_libros.Estado == "destruido" || actual->datos_libros.CantidadDisponible == 1)

					{
						ShowMessage("El libro no se puede dar a prestamo");
						return 0;

					}


					if (ReservarDias <= 7) {



						//	cout<<"Cantidad Actual"<<actual->datos_libros.CantidadDisponible<<endl;
						actual->datos_libros.CantidadDisponible -= libroReservar;

						//	cout<<"Cantidad Restantes:"<<actual->datos_libros.CantidadDisponible<<endl;
						fstream ArchivoPrestamo("Prestamos.csv", ios::app);

						if (!ArchivoPrestamo) {
							cout << "error al abrir el archivo prestamos";
							return 0;
						}
						ArchivoPrestamo << apellidoaux << "," << areaaux << "," << NombreLibroReservar << "," << ReservarDias << "," << fechadelprestamo << endl;

							ShowMessage("Se reservo correctamente");
						ArchivoPrestamo.close();
						GuardarListaLibrosEnCSV();
						return 0;

					} else {
                        ShowMessage("Te has excedido del tiempo limite para prestar un libro");
					}




				}


				actual = actual->siguiente;
			}

			if (bandera == 0) {
				ShowMessage("EL AREA DEL LIBRO O EL NOMBRE LIBRO NO FUE ENCONTRADO");

				return 0;
			}






					return 0;

		}
		actualSocios = actualSocios->siguiente;

	}
	if(SocioEncontrado==0)
	{
		ShowMessage("EL Apellido del socio buscado no existe");
	}

	return 0;
}


