void Libros::AgregarLibrosCSV(struct Estructura_Libros Datos) {



	int bandera;
	do {
		bandera = 0;

		NodoLibros*actual = PrimerNodo1;
		while (actual != nullptr && bandera != 1) {
			if (Datos.Id == actual->datos_libros.Id) {
					ShowMessage("El ID Ya existe , Ingrese otro.");
					return;
				bandera = 1;
			}
			 else if(Datos.Estado!="bien"&&Datos.Estado!="regular"&&Datos.Estado!="malo"&&Datos.Estado!="destruido")
			{
					 ShowMessage("El estado que escribiste no existe , Ingrese otro.");
					return;
                    bandera=1;
			}

			else {
				bandera = 0;
			}
			actual = actual->siguiente;
		}

	} while (bandera == 1);


	if (Datos.Area == "Matematicas") {
		Datos.ubicacion = "Pasillo 1";
	} else if (Datos.Area == "Ingenieria") {
		Datos.ubicacion = "Pasillo 2";
	} else if (Datos.Area == "Quimica") {
		Datos.ubicacion = "Pasillo 3";
	} else if (Datos.Area == "Fisica") {
		Datos.ubicacion = "Pasillo 4";
	} else if (Datos.Area == "Informatica") {
		Datos.ubicacion = "Pasillo 5";
	} else if (Datos.Area == "Biologia") {
		Datos.ubicacion = "Pasillo 6";
	} else if (Datos.Area == "Ciencias") {
		Datos.ubicacion = "Pasillo 7";
	} else {
		Datos.ubicacion = "Pasillo General";
	}

            ShowMessage("Libro Registrado Exitosamente");
	AgregarLibrosALista(Datos);
    
	
	fstream ArchivoCodigoBarra("CodigoBarra.csv",ios::app);
	if(!ArchivoCodigoBarra)
	{
		cout<<"error al abrir el archivo CodigodeBarra"<<endl;
	}
	
		ArchivoCodigoBarra<<Datos.Id<<Datos.ubicacion<<Datos.Estado<<Datos.CantidadDisponible<<endl;
	

	ArchivoCodigoBarra.close();
	

	fstream ArchivoLibros("ListaLibros.csv", ios::app);

	if (!ArchivoLibros) {
		cout << "error al abrir el archivo ListaLibros en modo añadir\n";
