void Libros::CargarLibrosDesdecsv() {

	string registro;
	string idaux;
	string auxcantdisponible;

	Estructura_Libros datos;

	fstream ArchivoLibros("ListaLibros.csv", ios::in);
	if (!ArchivoLibros) {
		cout << "error al abrir el archivo ListaLibros en modo lectura";
		return;
	}

	while (getline(ArchivoLibros, registro)) {



		stringstream token(registro);
		getline(token, idaux, ',');
		datos.Id = stoi(idaux);
		getline(token, datos.Nombre, ',');
		getline(token, datos.Area, ',');
		getline(token,datos.ubicacion,',');
		getline(token, datos.SubArea, ',');
		getline(token, datos.Autores, ',');
		getline(token, datos.Editorial, ',');
		getline(token, datos.AnoPublicacion, ',');
		getline(token, datos.Estado, ',');
		getline(token, auxcantdisponible, ',');
		datos.CantidadDisponible = stoi(auxcantdisponible);

		AgregarLibrosALista(datos);
	}

	ArchivoLibros.close();



}
