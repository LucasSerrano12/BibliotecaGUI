void Libros::VerPrestamos(TStringGrid* grid) {


	fstream APrestamos("Prestamos.csv", ios::in);
	if (!APrestamos) {
		cout << "error al abrir el archivo ListaLibros en modo lectura";
		return;
	}

	string registro;
     int fila = 1;

	grid->ColCount = 5;
    grid->RowCount = 1;
	grid->Cells[0][0] = "Apellido";
	grid->Cells[1][0] = "Area";
	grid->Cells[2][0] = "Nombre del Libro";
	grid->Cells[3][0] = "Dias";
    grid->Cells[4][0] = "Fecha del Prestamo";

	while (getline(APrestamos,registro)) {
		stringstream token(registro);
        string campo;
        int columna = 0;

        grid->RowCount = fila + 1;

		while (getline(token,campo,',')) {
			AnsiString valor = campo.c_str();
            grid->Cells[columna][fila] = valor;
			columna++;
		}

        fila++;
    }

    APrestamos.close();
}

