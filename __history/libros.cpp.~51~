int Libros::buscarlibro(string Areaaux , TStringGrid* grid) {
	NodoLibros *actual = PrimerNodo1;


	int bandera = 0;
	int fila=1;
	grid->RowCount = 1;
	grid->Cells[0][0] = "ID";
	grid->Cells[1][0] = "Nombre";
	grid->Cells[2][0] = "Area";
	grid->Cells[3][0] = "SubArea";
	grid->Cells[4][0] = "Autores";
	grid->Cells[5][0] = "Editorial";
	grid->Cells[6][0] = "Año Publicacion";
	grid->Cells[7][0] = "Estado";
	grid->Cells[8][0] = "Cant.";
	grid->Cells[9][0] = "Ubicacion";

	while (actual != nullptr) {
		if (Areaaux == actual->datos_libros.Area ) {
			 grid->RowCount = fila + 1;
			grid->Cells[0][fila] = IntToStr(actual->datos_libros.Id);
			grid->Cells[1][fila] = actual->datos_libros.Nombre.c_str();
			grid->Cells[2][fila] = actual->datos_libros.Area.c_str();
			grid->Cells[3][fila] = actual->datos_libros.SubArea.c_str();
			grid->Cells[4][fila] = actual->datos_libros.Autores.c_str();
			grid->Cells[5][fila] = actual->datos_libros.Editorial.c_str();
			grid->Cells[6][fila] = actual->datos_libros.AnoPublicacion.c_str();
			grid->Cells[7][fila] = actual->datos_libros.Estado.c_str();
			grid->Cells[8][fila] = IntToStr(actual->datos_libros.CantidadDisponible);
			grid->Cells[9][fila] = actual->datos_libros.ubicacion.c_str();
			fila++;
			bandera = 1;
		}

		actual = actual->siguiente;

	}
	if (bandera == 0) {
				ShowMessage("El libro Buscado no existe");
	}




}


