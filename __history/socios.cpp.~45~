Socios::Socios() {

	primerNodo = nullptr;
}

Socios::~Socios() {

}

void Socios::AgregarSocioALista(Estructura_Socios datos) {
	NodoSocios* nuevoNodo = new NodoSocios;
	nuevoNodo->datos_socios = datos;
	nuevoNodo->siguiente = primerNodo;
	primerNodo = nuevoNodo;

}



void Socios::AgregarSocioCSV(struct Estructura_Socios Datos) {


	AgregarSocioALista(Datos);

	fstream ArchivoSocios("ListaSocios.csv", ios::app);

	if (!ArchivoSocios) {
		return;
	}

	ArchivoSocios << Datos.Apellido << "," << Datos.Genero << ","
	              << Datos.Direccion << "," << Datos.NumTelefonico << "," << Datos.Edad << "," << Datos.FechaNac << "," << Datos.CorreoElectronico << endl;

	ArchivoSocios.close();
     	
}


void Socios::CargarSociosDesdecsv() {

	string registro;


	Estructura_Socios datos;

	fstream ArchivoSocios("ListaSocios.csv", ios::in);
	if (!ArchivoSocios) {

		return;
	}

	while (getline(ArchivoSocios, registro)) {
		string telefonoaux, edadaux;

		stringstream token(registro);

		getline(token, datos.Apellido, ',');
		getline(token, datos.Genero, ',');
		getline(token, datos.Direccion, ',');
		getline(token, datos.NumTelefonico, ',');
		getline(token, edadaux, ',');
		datos.Edad = stoi(edadaux);
		getline(token, datos.FechaNac, ',');
		getline(token, datos.CorreoElectronico, ',');

		AgregarSocioALista(datos);
	}

	ArchivoSocios.close();



}

int Socios::contarSocios() {
    int contador = 0;
	NodoSocios* actual = primerNodo;
	while (actual != nullptr) {
		contador++;
		actual = actual->siguiente;
    }
    return contador;
}


