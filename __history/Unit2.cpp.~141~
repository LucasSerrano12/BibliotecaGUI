void __fastcall TForm2::MostrarSocios() {
	NodoSocios* actual = listaSocios.primerNodo;

	int cantidad = 0;
	NodoSocios* temp = actual;
	while (temp != nullptr) {
		cantidad++;
		temp = temp->siguiente;
	}

	PlanillaMostrarSocio->RowCount = cantidad + 1;

	// Opcional: agregar encabezados si es la primera vez
	PlanillaMostrarSocio->Cells[0][0] = "Apellido";
	PlanillaMostrarSocio->Cells[1][0] = "Género";
	PlanillaMostrarSocio->Cells[2][0] = "Dirección";
	PlanillaMostrarSocio->Cells[3][0] = "Teléfono";
	PlanillaMostrarSocio->Cells[4][0] = "Edad";
	PlanillaMostrarSocio->Cells[5][0] = "Nacimiento";
	PlanillaMostrarSocio->Cells[6][0] = "Correo";

	int fila = 1;
	while (actual != nullptr) {
		PlanillaMostrarSocio->Cells[0][fila] = actual->datos_socios.Apellido.c_str();
		PlanillaMostrarSocio->Cells[1][fila] = actual->datos_socios.Genero.c_str();
		PlanillaMostrarSocio->Cells[2][fila] = actual->datos_socios.Direccion.c_str();
		PlanillaMostrarSocio->Cells[3][fila] = actual->datos_socios.NumTelefonico.c_str();
		PlanillaMostrarSocio->Cells[4][fila] = IntToStr(actual->datos_socios.Edad);
		PlanillaMostrarSocio->Cells[5][fila] = actual->datos_socios.FechaNac.c_str();
		PlanillaMostrarSocio->Cells[6][fila] = actual->datos_socios.CorreoElectronico.c_str();

		actual = actual->siguiente;
		fila++;
	}
}

