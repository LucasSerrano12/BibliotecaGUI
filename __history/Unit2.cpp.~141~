void __fastcall TForm2::BotonRegistrarAgregarSocioClick(TObject *Sender)
{
		  struct Estructura_Socios Datos;
// Obtener datos desde la interfaz
	AnsiString apellido = CasillaApellido->Text;
	AnsiString genero = GeneroM->Checked ? "Masculino" : (GeneroF->Checked ? "Femenino" : "");
	AnsiString direccion = CasillaDireccion->Text;
	AnsiString telefono = CasillaTelefono->Text;
	AnsiString edad = CasillaEdad->Text;
	AnsiString nacimiento = DateToStr(CasillaFechaNac->Date);
	AnsiString correo = CasillaCorreo->Text;

	// Validación básica
	if (apellido.IsEmpty() || genero.IsEmpty() || direccion.IsEmpty() || telefono.IsEmpty()
		|| edad.IsEmpty() || nacimiento.IsEmpty() || correo.IsEmpty()) {
		ShowMessage("Por favor, complete todos los campos.");
		return;
	}

	// Convertir a string estándar
	Datos.Apellido = apellido.c_str();
	Datos.Genero = genero.c_str();
	Datos.Direccion = direccion.c_str();
	Datos.NumTelefonico = telefono.c_str();
	Datos.Edad = stoi(edad.c_str());
	Datos.FechaNac = nacimiento.c_str();
	Datos.CorreoElectronico = correo.c_str();

	listaSocios.AgregarSocioCSV(Datos);



	ShowMessage("Socio Registrado Exitosamente");



	CasillaApellido->Text="";
	CasillaDireccion->Text="";
	CasillaTelefono->Text="";
	CasillaEdad->Text="";
    CasillaCorreo->Text="";
}
